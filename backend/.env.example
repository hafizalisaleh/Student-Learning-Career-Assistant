# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/slca_db
POSTGRES_USER=slca_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=slca_db

# JWT Authentication
SECRET_KEY=your-secret-key-here-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# AI Services - Google Gemini
GOOGLE_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Groq API (primary LLM + Vision)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
LLM_CHOICE=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Provider routing
RAG_LLM_PROVIDER=groq
RAG_VISION_PROVIDER=groq
RAG_VISION_MODE=auto

# Ollama (optional local text + vision)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3.5:0.8b
OLLAMA_VISION_MODEL=qwen3.5:0.8b
OLLAMA_NUM_CTX=16384

# Local Embeddings (HuggingFace - runs locally, no API key needed)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
EMBEDDING_DEVICE=auto  # auto, cpu, cuda, mps

# Docling ingestion + vision defaults (mirrors the original CLI workflow)
DOCLING_HYBRID_TOKENIZER=sentence-transformers/all-MiniLM-L6-v2
DOCLING_HYBRID_MAX_TOKENS=128
DOCLING_HYBRID_MERGE_PEERS=False
DOCLING_FORMULA_ENRICHMENT=True
DOCLING_ENABLE_PDF_PAGE_OCR=True
DOCLING_PDF_OCR_DPI=200
DOCLING_PDF_OCR_MIN_CHARS=20
DOCLING_IMAGE_SCALE=1.5
DOCLING_GENERATE_PICTURE_IMAGES=True
DOCLING_GENERATE_TABLE_IMAGES=True
VISION_CACHE_DIR=.vision_cache
VISION_QUERY_DEFAULT_LIMIT=6
VISION_MAX_IMAGES=3
VISION_RESPONSES_MD=runtime/vision_responses.md

# YouTube Transcript API (Supadata)
SUPADATA_API_KEY=your-supadata-api-key

# Web Content Extraction
EXTRACTOR_API_KEY=your-extractor-api-key

# OCR Service
OCR_API_KEY=your-ocr-api-key
OCR_API_SECRET=your-ocr-api-secret
OCR_API_URL=https://www.imagetotext.com/api/ocr
OCR_SERVICE=api  # Options: tesseract, api

# File Storage
MAX_FILE_SIZE_MB=50
UPLOAD_FOLDER=uploads/
ALLOWED_EXTENSIONS=pdf,docx,doc,pptx,ppt,xlsx,xls,csv,txt,md,json,jpg,jpeg,png,bmp,tiff,tif

# Email Service (for verification)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@slca.com

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True
